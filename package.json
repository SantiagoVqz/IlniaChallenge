{
  "name": "my-expo-app",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "db:staging": "supabase start --workdir infra/staging",
    "db:production": "supabase start --workdir infra/production",
    "db:staging:stop": "supabase stop --workdir infra/staging",
    "db:production:stop": "supabase stop --workdir infra/production",
    "api:staging": "dotenv -e .env.staging -- cross-env PORT=3000 node scripts/dev-server.mjs",
    "api:production": "dotenv -e .env.production -- cross-env PORT=3001 node scripts/dev-server.mjs",
    "start:staging": "dotenv -e .env.staging -- expo start -c",
    "start:production": "dotenv -e .env.production -- expo start -c"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "expo": "^54.0.0",
    "expo-secure-store": "^56.0.4",
    "expo-status-bar": "~3.0.8",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "@vercel/node": "^5.8.17",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "supabase": "^2.107.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2",
    "vercel": "^54.14.2"
  },
  "main": "node_modules/expo/AppEntry.js",
  "private": true
}
